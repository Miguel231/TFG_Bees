# Raw sensor data (large CSVs and xlsx exports)
data/*.csv
data/*.xlsx

# Experimental/intermediate trained models and data in notebooks/models/
notebooks/models/*.pkl
notebooks/models/*.pt
notebooks/models/*.joblib
notebooks/models/*.png
notebooks/models/*.csv
notebooks/models/*.txt

# API staging export folder
api_export/

# Deployed models are tracked under api/models/ — no ignore rule needed there

# Runtime artifacts generated by the API
api/debug_last_download.xlsx
api/latest_results.json
api/run_history.json

# Generated plots and figures
plots/
**/*.png
**/*.jpg
**/*.svg
!docs/images/*.png

# Jupyter artefacts
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment variables
.env

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
settings.local.json
